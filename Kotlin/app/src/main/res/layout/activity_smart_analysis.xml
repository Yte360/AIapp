<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_cyber_page">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_cyber_toolbar"
        app:title="考研题目智能解析"
        app:titleTextColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="#332A3A5E"
            android:backgroundTint="@color/cyber_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="输入题目"
                    android:textColor="@color/cyber_muted"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="96dp"
                    android:gravity="top"
                    android:hint="在此输入或粘贴考研题目..."
                    android:textColor="@color/cyber_text"
                    android:textColorHint="#66EAF2FF"
                    android:background="@android:color/transparent"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="开始解析"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_cyber_button" />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cyber_surface"
        app:tabIndicatorColor="@color/cyber_neon"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/cyber_text"
        app:tabTextColor="@color/cyber_muted"
        app:tabRippleColor="#3319C4E9" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/cyber_neon"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCards"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:clipToPadding="false" />

        <HorizontalScrollView
            android:id="@+id/scrollMindmap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <com.example.myapplication3.ui.view.MindMapView
                android:id="@+id/mindMapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </HorizontalScrollView>

        <com.example.myapplication3.ui.view.KnowledgeGraphView
            android:id="@+id/knowledgeGraphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>